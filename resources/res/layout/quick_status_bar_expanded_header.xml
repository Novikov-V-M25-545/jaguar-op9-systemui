<?xml version="1.0" encoding="utf-8"?>
<com.android.systemui.qs.QuickStatusBarHeader xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_gravity="bottom|clip_horizontal|right"
    android:id="@+id/header"
    android:background="@android:color/transparent"
    android:paddingTop="0dp"
    android:clickable="false"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:baselineAligned="false"
    android:paddingStart="0dp"
    android:paddingEnd="0dp"
    android:elevation="4dp">
    <include layout="@layout/quick_status_bar_header_system_icons"/>
    <include layout="@layout/quick_qs_status_icons"/>
    <include layout="@layout/quick_settings_header_info"/>
    <include
        android:id="@+id/quick_qs_brightness_bar"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="@dimen/brightness_mirror_height"
        android:layout_below="@+id/header_text_container"
        layout="@layout/quick_settings_brightness_dialog"/>
    <com.android.systemui.qs.QuickQSPanel
        android:id="@+id/quick_qs_panel"
        android:paddingBottom="10dp"
        android:focusable="true"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/quick_qs_brightness_bar"
        android:importantForAccessibility="yes"
        android:accessibilityTraversalBefore="@+id/expand_indicator"
        android:accessibilityTraversalAfter="@+id/date_time_group"/>
    <TextView
        android:textSize="11dp"
        android:textStyle="bold"
        android:textColor="#00a040"
        android:layout_gravity="center_vertical"
        android:id="@+id/header_debug_info"
        android:padding="2dp"
        android:visibility="invisible"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-condensed"/>
</com.android.systemui.qs.QuickStatusBarHeader>
