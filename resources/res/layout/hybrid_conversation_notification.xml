<?xml version="1.0" encoding="utf-8"?>
<com.android.systemui.statusbar.notification.row.HybridConversationNotificationView xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="start|center_vertical"
    android:paddingTop="1dp"
    android:paddingBottom="1dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingEnd="12dp">
    <FrameLayout
        android:layout_width="wrap_content"
        android:layout_height="25dp"
        android:paddingStart="14dp"
        android:paddingEnd="8dp">
        <ImageView
            android:layout_gravity="start|center_vertical"
            android:id="@android:id/clamp"
            android:layout_width="20dp"
            android:layout_height="20dp"/>
        <ViewStub
            android:layout_gravity="start|center_vertical"
            android:id="@android:id/chooser_edit_button"
            android:layout="@android:layout/chooser_grid_preview_image"
            android:layout_width="25dp"
            android:layout_height="25dp"/>
    </FrameLayout>
    <TextView
        android:textAppearance="@android:style/TextAppearance.DeviceDefault.ListItem"
        android:id="@+id/notification_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:singleLine="true"
        android:paddingEnd="8dp"/>
    <TextView
        android:id="@+id/conversation_notification_sender"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:singleLine="true"
        style="?attr/hybridNotificationTextStyle"/>
    <TextView
        android:id="@+id/notification_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:singleLine="true"
        style="?attr/hybridNotificationTextStyle"/>
</com.android.systemui.statusbar.notification.row.HybridConversationNotificationView>
