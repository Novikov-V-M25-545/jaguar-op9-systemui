<?xml version="1.0" encoding="utf-8"?>
<com.android.systemui.omni.DetailedWeatherView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:systemui="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/current_weather"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingStart="10dp"
        android:paddingEnd="10dp">
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:paddingStart="10dp"
            android:paddingEnd="10dp">
            <TextView
                android:textAppearance="@style/TextAppearance.StatusBar.Expanded.Weather.Detailed"
                android:ellipsize="end"
                android:gravity="start"
                android:layout_gravity="center_vertical"
                android:id="@+id/current_weather_city"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"/>
            <TextView
                android:textAppearance="@style/TextAppearance.StatusBar.Expanded.Weather.Detailed"
                android:gravity="end"
                android:layout_gravity="center_vertical"
                android:id="@+id/current_weather_data"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:layout_weight="1"/>
        </LinearLayout>
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:layout_gravity="center_vertical"
                android:orientation="vertical"
                android:id="@+id/current"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">
                <ImageView
                    android:layout_gravity="center_horizontal"
                    android:id="@+id/current_image"
                    android:paddingBottom="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:scaleType="centerInside"/>
                <TextView
                    android:textAppearance="@style/TextAppearance.StatusBar.Expanded.Weather.Detailed"
                    android:layout_gravity="center_horizontal"
                    android:id="@+id/current_temp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:singleLine="true"/>
                <TextView
                    android:textAppearance="@style/TextAppearance.StatusBar.Expanded.Weather.Detailed"
                    android:layout_gravity="center_horizontal"
                    android:id="@+id/current_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:singleLine="true"/>
            </LinearLayout>
            <LinearLayout
                android:layout_gravity="center_vertical"
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">
                <ImageView
                    android:layout_gravity="center_horizontal"
                    android:id="@+id/forecast_image_0"
                    android:paddingBottom="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:scaleType="centerInside"/>
                <TextView
                    android:textAppearance="@style/TextAppearance.StatusBar.Expanded.Weather.Detailed"
                    android:layout_gravity="center_horizontal"
                    android:id="@+id/forecast_temp_0"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:singleLine="true"/>
                <TextView
                    android:textAppearance="@style/TextAppearance.StatusBar.Expanded.Weather.Detailed"
                    android:layout_gravity="center_horizontal"
                    android:id="@+id/forecast_text_0"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:singleLine="true"/>
            </LinearLayout>
            <LinearLayout
                android:layout_gravity="center_vertical"
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">
                <ImageView
                    android:layout_gravity="center_horizontal"
                    android:id="@+id/forecast_image_1"
                    android:paddingBottom="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:scaleType="centerInside"/>
                <TextView
                    android:textAppearance="@style/TextAppearance.StatusBar.Expanded.Weather.Detailed"
                    android:layout_gravity="center_horizontal"
                    android:id="@+id/forecast_temp_1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:singleLine="true"/>
                <TextView
                    android:textAppearance="@style/TextAppearance.StatusBar.Expanded.Weather.Detailed"
                    android:layout_gravity="center_horizontal"
                    android:id="@+id/forecast_text_1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:singleLine="true"/>
            </LinearLayout>
            <LinearLayout
                android:layout_gravity="center_vertical"
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">
                <ImageView
                    android:layout_gravity="center_horizontal"
                    android:id="@+id/forecast_image_2"
                    android:paddingBottom="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:scaleType="centerInside"/>
                <TextView
                    android:textAppearance="@style/TextAppearance.StatusBar.Expanded.Weather.Detailed"
                    android:layout_gravity="center_horizontal"
                    android:id="@+id/forecast_temp_2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:singleLine="true"/>
                <TextView
                    android:textAppearance="@style/TextAppearance.StatusBar.Expanded.Weather.Detailed"
                    android:layout_gravity="center_horizontal"
                    android:id="@+id/forecast_text_2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:singleLine="true"/>
            </LinearLayout>
            <LinearLayout
                android:layout_gravity="center_vertical"
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">
                <ImageView
                    android:layout_gravity="center_horizontal"
                    android:id="@+id/forecast_image_3"
                    android:paddingBottom="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:scaleType="centerInside"/>
                <TextView
                    android:textAppearance="@style/TextAppearance.StatusBar.Expanded.Weather.Detailed"
                    android:layout_gravity="center_horizontal"
                    android:id="@+id/forecast_temp_3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:singleLine="true"/>
                <TextView
                    android:textAppearance="@style/TextAppearance.StatusBar.Expanded.Weather.Detailed"
                    android:layout_gravity="center_horizontal"
                    android:id="@+id/forecast_text_3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:singleLine="true"/>
            </LinearLayout>
            <LinearLayout
                android:layout_gravity="center_vertical"
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">
                <ImageView
                    android:layout_gravity="center_horizontal"
                    android:id="@+id/forecast_image_4"
                    android:paddingBottom="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:scaleType="centerInside"/>
                <TextView
                    android:textAppearance="@style/TextAppearance.StatusBar.Expanded.Weather.Detailed"
                    android:layout_gravity="center_horizontal"
                    android:id="@+id/forecast_temp_4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:singleLine="true"/>
                <TextView
                    android:textAppearance="@style/TextAppearance.StatusBar.Expanded.Weather.Detailed"
                    android:layout_gravity="center_horizontal"
                    android:id="@+id/forecast_text_4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:singleLine="true"/>
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:paddingStart="10dp"
            android:paddingEnd="10dp">
            <TextView
                android:textAppearance="@style/TextAppearance.StatusBar.Expanded.Weather.Detailed"
                android:gravity="start"
                android:layout_gravity="center_vertical"
                android:id="@+id/current_weather_provider"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"/>
            <TextView
                android:textAppearance="@style/TextAppearance.StatusBar.Expanded.Weather.Detailed"
                android:gravity="end"
                android:layout_gravity="center_vertical"
                android:id="@+id/current_weather_timestamp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"/>
        </LinearLayout>
    </LinearLayout>
    <LinearLayout
        android:gravity="center"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:id="@android:id/empty"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <ImageView
            android:id="@+id/empty_weather_image"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:tint="?android:attr/textColorSecondary"
            android:alpha="0.14"/>
        <TextView
            android:textAppearance="@style/TextAppearance.StatusBar.Expanded.Weather.Detailed"
            android:id="@+id/status_msg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="center"
        android:layout_gravity="center"
        android:id="@+id/progress_container"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <ProgressBar
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="?android:attr/progressBarStyle"/>
    </LinearLayout>
</com.android.systemui.omni.DetailedWeatherView>
