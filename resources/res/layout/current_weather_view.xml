<?xml version="1.0" encoding="utf-8"?>
<com.android.systemui.omni.CurrentWeatherView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:systemui="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <LinearLayout
        android:gravity="center"
        android:layout_gravity="center"
        android:orientation="horizontal"
        android:id="@+id/current"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="16dp"
        android:layout_marginRight="16dp">
        <TextView
            android:textColor="?attr/wallpaperTextColor"
            android:ellipsize="end"
            android:gravity="center"
            android:id="@+id/left_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:paddingEnd="8dp"
            style="@style/TextAppearance.Keyguard"/>
        <ImageView
            android:id="@+id/current_image"
            android:layout_width="@dimen/current_weather_image_size"
            android:layout_height="@dimen/current_weather_image_size"
            android:scaleType="centerInside"/>
        <TextView
            android:textColor="?attr/wallpaperTextColor"
            android:gravity="center"
            android:id="@+id/right_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:paddingStart="8dp"
            style="@style/TextAppearance.Keyguard"/>
    </LinearLayout>
</com.android.systemui.omni.CurrentWeatherView>
