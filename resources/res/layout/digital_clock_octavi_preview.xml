<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center"
    android:layout_gravity="center"
    android:orientation="vertical"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:layout_alignParentTop="true">
    <LinearLayout
        android:gravity="center"
        android:layout_gravity="start"
        android:orientation="horizontal"
        android:id="@+id/clock_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextClock
            android:textSize="46sp"
            android:textColor="?attr/wallpaperTextColor"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@+id/clock_day"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:textAllCaps="true"
            android:fontFamily="@android:string/config_defaultCredentialManagerHybridService"
            android:format12Hour=" EEEE "
            android:format24Hour=" EEEE "/>
        <LinearLayout
            android:gravity="center"
            android:orientation="horizontal"
            android:id="@+id/datelayout"
            android:background="@drawable/elegantClockBg"
            android:layout_width="44dp"
            android:layout_height="44dp">
            <TextClock
                android:textSize="22sp"
                android:textColor="?attr/wallpaperTextColor"
                android:gravity="center"
                android:layout_gravity="center"
                android:id="@+id/date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:textAllCaps="true"
                android:fontFamily="@android:string/config_defaultCredentialManagerHybridService"
                android:format12Hour=" dd "
                android:format24Hour=" dd "/>
        </LinearLayout>
    </LinearLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/clock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="-5dp"
        android:layout_marginStart="5dp">
        <TextClock
            android:textSize="22sp"
            android:textColor="?attr/wallpaperTextColor"
            android:gravity="start"
            android:layout_gravity="center"
            android:id="@+id/time_clock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:textAllCaps="true"
            android:fontFamily="@android:string/config_defaultCredentialManagerHybridService"
            android:format12Hour=" hh:mm "
            android:format24Hour=" HH:mm "/>
    </LinearLayout>
</LinearLayout>
